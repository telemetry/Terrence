   <crs:Description>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Night cinema. Teal shadows against tungsten-warm highlights, protected skin, glowing signs. CineStill spirit for the city after dark and moody daylight.</rdf:li>
    </rdf:Alt>
   </crs:Description>
  </rdf:Description>
