   <crs:Name>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Terra 05 — Harbor</rdf:li>
    </rdf:Alt>
   </crs:Name>
   <crs:ShortName>
    <rdf:Alt>
     <rdf:li xml:lang="x-default"/>
