   <crs:Description>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Golden-hour nostalgia. Amber light poured over everything, sunny yellows, warm matte toe. Gold 200 spirit, unapologetic.</rdf:li>
    </rdf:Alt>
   </crs:Description>
