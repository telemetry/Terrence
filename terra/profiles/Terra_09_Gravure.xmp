   <crs:Description>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Punchy monochrome. Deep blacks, bright honest highlights, red-leaning mix that darkens skies and lifts skin. Tri-X spirit for street.</rdf:li>
    </rdf:Alt>
