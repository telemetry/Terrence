   <crs:Description>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Silver and severe. Bleach-bypass restraint — color pulled nearly to metal, high contrast, skin left breathing. For hard light, concrete, winter.</rdf:li>
    </rdf:Alt>
   </crs:Description>
  </rdf:Description>
