   <crs:Name>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Terra 08 — Slate</rdf:li>
    </rdf:Alt>
   </crs:Name>
   <crs:ShortName>
    <rdf:Alt>
     <rdf:li xml:lang="x-default"/>
    </rdf:Alt>
