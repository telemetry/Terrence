   <crs:Description>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Muted documentary. Restrained color, hard honest shadows, suppressed magenta, a whisper of amber in the toe. Classic Chrome spirit for street and travel.</rdf:li>
    </rdf:Alt>
   </crs:Description>
  </rdf:Description>
