   <crs:Name>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Terra 03 — Field</rdf:li>
    </rdf:Alt>
   </crs:Name>
   <crs:ShortName>
    <rdf:Alt>
     <rdf:li xml:lang="x-default"/>
