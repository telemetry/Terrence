   <crs:Description>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">The warm anchor. Creamy golden highlights, cool matte shadows, quiet olive greens, skin first. Portra spirit, assertive build.</rdf:li>
    </rdf:Alt>
